# ==============================================================================
# DV-Agent Configuration Environment Variables
# ==============================================================================
#
# Copy this file to `.env` and adjust the values to match your local
# LLM infrastructure (e.g., vLLM, text-generation-webui, Ollama, etc.)
# Note: Actual `.env` files are ignored by git to prevent credential leaks.

# The base URL of your local OpenAI-compatible API endpoint.
LOCAL_API_URL="http://localhost:8080/v1"

# The API key required to authenticate. For many local endpoints, this is
# ignored, but Langchain/OpenAI client requires a non-empty string.
# Using "EMPTY" is typically recommended for keyless endpoints.
LOCAL_API_KEY="EMPTY"

# The identifier of the specific model to request from your local endpoint.
LOCAL_MODEL_NAME="local-model"
